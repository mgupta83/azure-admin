# Azure Application Configuration
VITE_AZURE_CLIENT_ID=your-azure-client-id-here
VITE_AZURE_TENANT_ID=your-azure-tenant-id-here

# API Endpoints (usually don't need to change these)
VITE_AZURE_AUTHORITY=https://login.microsoftonline.com/common/v2.0
VITE_AZURE_GRAPH_ENDPOINT=https://graph.microsoft.com/v1.0
VITE_AZURE_MANAGEMENT_ENDPOINT=https://management.azure.com

# Development settings
VITE_DEV_MODE=true